-- Fungsi pelacak Frame Utama & ScreenGui induk NeverLose
local function GetNeverLoseElements()
    local targets = {CoreGui, LocalPlayer:WaitForChild("PlayerGui")}
    for _, location in pairs(targets) do
        for _, obj in pairs(location:GetDescendants()) do
            if obj:IsA("ImageLabel") and string.find(obj.Image, "104247466652462") then
                local current = obj
                while current and current.Parent do
                    if current:IsA("Frame") and current.Parent:IsA("ScreenGui") then
                        return current, current.Parent -- Mengembalikan MainFrame dan ScreenGui induknya
                    end
                    current = current.Parent
                end
            end
        end
    end
    return nil, nil
end

-- Fungsi Pembersih Kotak Kaca Fisik & Efek DOF
local function Clear3DGlassBoxes(shouldHide)
    pcall(function()
        for _, obj in pairs(Lighting:GetChildren()) do
            if obj:IsA("DepthOfFieldEffect") then
                obj.NearIntensity = shouldHide and 0 or 1
                obj.Enabled = not shouldHide
            end
        end
        
        if Camera and shouldHide then
            for _, obj in pairs(Camera:GetChildren()) do
                if obj:IsA("BasePart") and obj.Material == Enum.Material.Glass then
                    obj:Destroy()
                end
            end
        end
    end)
end

-- State Tracker Utama
local GuiVisible = true

-- // FUNGSI TOGGLE UTAMA: AMAN & ANTI-GESER // --
local function ActionToggle(forceState)
    local MainFrame, ParentGui = GetNeverLoseElements()
    if not MainFrame or not ParentGui then return end

    if forceState ~= nil then
        GuiVisible = forceState
    else
        GuiVisible = not GuiVisible
    end

    pcall(function()
        -- KUNCI POSISI: Simpan posisi asli saat pertama kali ditemukan agar tidak bisa bergeser lagi
        if not MainFrame:GetAttribute("FixedPosition") then
            MainFrame:SetAttribute("FixedPosition", MainFrame.Position)
        end

        -- Selalu paksa posisi kembali ke posisi awal mula muncul (mengunci posisi)
        MainFrame.Position = MainFrame:GetAttribute("FixedPosition")

        if not GuiVisible then
            -- AKSI MINIMIZE: Matikan visibility ScreenGui induk agar tidak bug/terpotong
            ParentGui.Enabled = false
            Clear3DGlassBoxes(true)
            Stroke.Color = Color3.fromRGB(40, 40, 40) -- Abu-abu
        else
            -- AKSI MAXIMIZE: Hidupkan kembali ScreenGui induk
            ParentGui.Enabled = true
            Clear3DGlassBoxes(false)
            Stroke.Color = Color3.fromRGB(0, 255, 120) -- Hijau
        end
    end)
end

-- Trigger 1: Klik pada Tombol Floating di layar
MaxBtn.MouseButton1Click:Connect(function()
